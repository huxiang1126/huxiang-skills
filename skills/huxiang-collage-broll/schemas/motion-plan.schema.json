{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://huxiang.local/schemas/collage-broll/motion-plan.schema.json",
  "title": "Timeline collage motion choreography",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "scene_id", "duration", "strategy", "motion_budget", "tracks", "events"],
  "properties": {
    "version": {"const": "1.0.0"},
    "scene_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "duration": {"type": "number", "exclusiveMinimum": 0},
    "strategy": {"type": "string", "minLength": 1},
    "motion_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dominant_track_ids", "max_simultaneous_high_intensity"],
      "properties": {
        "dominant_track_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {"type": "string"},
          "uniqueItems": true
        },
        "max_simultaneous_high_intensity": {"type": "integer", "minimum": 1, "maximum": 3},
        "quiet_windows": {
          "type": "array",
          "items": {"$ref": "#/$defs/window"}
        }
      }
    },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["track_id", "layer_id", "importance", "end_behavior", "phases"],
        "properties": {
          "track_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
          "layer_id": {"type": "string", "minLength": 1},
          "importance": {"enum": ["hero", "support", "background"]},
          "end_behavior": {"enum": ["exit", "hold_to_cut", "handoff"]},
          "phases": {
            "type": "array",
            "minItems": 2,
            "items": {"$ref": "#/$defs/motionPhase"}
          }
        }
      }
    },
    "events": {
      "type": "array",
      "items": {"$ref": "#/$defs/sceneEvent"}
    }
  },
  "$defs": {
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "number", "minimum": 0},
        "end": {"type": "number", "exclusiveMinimum": 0},
        "reason": {"type": "string"}
      }
    },
    "motionPhase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase_id",
        "phase",
        "start",
        "end",
        "driver",
        "family",
        "runtime",
        "rule",
        "intention",
        "intensity",
        "finite"
      ],
      "properties": {
        "phase_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
        "phase": {"enum": ["enter", "settle", "hold", "action", "reaction", "exit"]},
        "start": {"type": "number", "minimum": 0},
        "end": {"type": "number", "exclusiveMinimum": 0},
        "driver": {
          "enum": ["narration", "sfx", "bgm", "scene_event", "environment", "transition", "manual"]
        },
        "family": {
          "enum": [
            "transform",
            "mask",
            "pose_swap",
            "light",
            "texture",
            "deformation",
            "particle",
            "composite",
            "camera",
            "video_overlay",
            "simulation"
          ]
        },
        "runtime": {
          "enum": ["gsap", "svg", "canvas2d", "css", "lottie", "three", "video", "editor_native"]
        },
        "rule": {"type": "string", "minLength": 1},
        "intention": {"type": "string", "minLength": 1},
        "intensity": {"type": "integer", "minimum": 1, "maximum": 5},
        "finite": {"const": true},
        "parameters": {"type": "object"}
      }
    },
    "sceneEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "category",
        "effect",
        "cause",
        "start",
        "end",
        "targets",
        "runtime",
        "intensity",
        "audio_source",
        "sound_policy"
      ],
      "properties": {
        "event_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
        "category": {
          "enum": [
            "impact",
            "energy",
            "atmosphere",
            "illumination",
            "destruction",
            "weather",
            "music_response",
            "texture",
            "transition",
            "other"
          ]
        },
        "effect": {"type": "string", "minLength": 1},
        "cause": {"type": "string", "minLength": 1},
        "start": {"type": "number", "minimum": 0},
        "end": {"type": "number", "exclusiveMinimum": 0},
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"},
          "uniqueItems": true
        },
        "runtime": {
          "enum": ["gsap", "svg", "canvas2d", "css", "lottie", "three", "video", "editor_native"]
        },
        "intensity": {"type": "integer", "minimum": 1, "maximum": 5},
        "audio_source": {"enum": ["none", "narration", "sfx", "bgm"]},
        "sound_policy": {"enum": ["sfx", "music_sync", "silent_by_design"]},
        "sfx_cue": {"type": "string"},
        "parameters": {"type": "object"}
      }
    }
  }
}
