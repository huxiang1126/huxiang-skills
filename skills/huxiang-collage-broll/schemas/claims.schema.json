{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://huxiang.local/schemas/collage-broll/claims.schema.json",
  "title": "Factual claims ledger",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "claims"],
  "properties": {
    "version": {"const": "2.3.0"},
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "claim", "status", "sources", "story_use"],
        "properties": {
          "claim_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
          "claim": {"type": "string", "minLength": 1},
          "status": {"enum": ["verified", "contested", "inference", "omit"]},
          "sources": {
            "type": "array",
            "items": {"type": "string", "format": "uri"},
            "minItems": 1,
            "uniqueItems": true
          },
          "story_use": {"type": "string", "minLength": 1},
          "qualification": {"type": "string", "minLength": 1},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
