{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://huxiang.local/schemas/collage-broll/asset-collage.schema.json",
  "title": "Timeline collage asset plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "scene_id", "canvas", "beat_ids", "layers"],
  "properties": {
    "version": {"const": "1.1.0"},
    "scene_id": {"type": "string", "minLength": 1},
    "canvas": {"type": "string", "minLength": 1},
    "beat_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "file", "role", "beat_ids", "z", "anchor", "initial", "keyframes"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
          "file": {"type": "string", "minLength": 1},
          "role": {"enum": ["hero", "support", "background", "decorative"]},
          "beat_ids": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"},
            "uniqueItems": true
          },
          "z": {"type": "integer"},
          "anchor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["x", "y"],
            "properties": {
              "x": {"type": "number"},
              "y": {"type": "number"}
            }
          },
          "initial": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "x": {"type": "number"},
              "y": {"type": "number"},
              "scale": {"type": "number", "exclusiveMinimum": 0},
              "rotation": {"type": "number"},
              "opacity": {"type": "number", "minimum": 0, "maximum": 1}
            }
          },
          "keyframes": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["at"],
              "properties": {
                "at": {"type": "number", "minimum": 0},
                "x": {"type": "number"},
                "y": {"type": "number"},
                "scale": {"type": "number", "exclusiveMinimum": 0},
                "rotation": {"type": "number"},
                "opacity": {"type": "number", "minimum": 0, "maximum": 1}
              }
            }
          }
        }
      }
    }
  }
}
