{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://huxiang.local/schemas/hx-collage-video/caption-safe-zones.schema.json",
  "title": "Dynamic caption safe zones",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "canvas",
    "caption_selector",
    "intersection_threshold_px2",
    "sample_interval_seconds",
    "beats"
  ],
  "properties": {
    "version": {"const": "2.3.0"},
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1}
      }
    },
    "caption_selector": {"type": "string", "minLength": 1},
    "intersection_threshold_px2": {"type": "number", "minimum": 0},
    "sample_interval_seconds": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 0.5
    },
    "beats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["caption_id", "selector", "start", "end", "regions"],
        "properties": {
          "caption_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
          "selector": {"type": "string", "minLength": 1},
          "start": {"type": "number", "minimum": 0},
          "end": {"type": "number", "exclusiveMinimum": 0},
          "samples": {
            "type": "array",
            "items": {"type": "number", "minimum": 0},
            "minItems": 3
          },
          "regions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "kind", "keyframes"],
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "kind": {
                  "enum": [
                    "person",
                    "person_action",
                    "face",
                    "hand",
                    "tool",
                    "primary_object"
                  ]
                },
                "keyframes": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["at", "x", "y", "width", "height"],
                    "properties": {
                      "at": {"type": "number", "minimum": 0},
                      "x": {"type": "number"},
                      "y": {"type": "number"},
                      "width": {"type": "number", "exclusiveMinimum": 0},
                      "height": {"type": "number", "exclusiveMinimum": 0}
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
